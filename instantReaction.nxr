      color: 'cyan',
      icon: 'ℹ️',
      message: 'Optimizacija primijenjena',
      notification: false
    }
  },
  
  fileExtensions: ['.pej', '.nxs', '.nxc'],
  
  settings: {
    reactionTime: 'instant',
    showNotifications: true,
    autoSave: true,
    darkTheme: true,
    language: 'Pejic'
  }
};

